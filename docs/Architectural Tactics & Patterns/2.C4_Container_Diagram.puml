@startuml C4_Container_Diagram
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Arial
skinparam rectangleBorderColor #555
skinparam arrowColor #444

title ScribeHealth AI — C4 Container Diagram

actor "Doctor" as Doctor #LightSteelBlue
actor "Administrator" as Admin #LightSalmon

rectangle "ScribeHealth AI [System Boundary]" #FFFFF0 {

  rectangle "Next.js Frontend\n[Container: TypeScript / React 19]\n\nApp Router pages, API routes,\nZustand state, audio capture,\nsession state machine, review UI" as FE #D6EAF8

  rectangle "Spring Boot Backend\n[Container: Java 17 / Spring Boot 3.2]\n\nREST API, JWT auth filter,\nService Layer, Facade, State + Observer\npatterns, PatientProfileBuilder" as BE #D5F5E3

  rectangle "AI Pipeline\n[Container: Next.js API Routes / TypeScript]\n\nTranscriptionServiceFactory (Factory Method)\nSoapNoteGenerator subclasses (Template Method)\nwithRetry() wrapper" as AI #FDEBD0

  rectangle "Audit & Admin\n[Container: Java / Spring Boot]\n\nAdminFacade, AuditService,\nappend-only audit_logs table,\nAdmin-only REST endpoints" as Audit #F9EBEA
}

cloud "Supabase\n[External: PostgreSQL + Storage + Realtime]\npatients, sessions, soap, entities,\naudit_logs, prescription_templates" as DB #E8F5E9
cloud "Sarvam AI\n[External: REST API]\nsaarika:v2.5 STT" as Sarvam #FFFACD
cloud "Anthropic Claude\n[External: REST API]\nHaiku + Sonnet" as Claude #FFF3E0
cloud "Notification Channels\n[External]\nEmail · WhatsApp · SMS" as Notify #F3E5F5

Doctor --> FE : "Uses browser\n[HTTPS]"
Admin --> FE : "Uses browser\n[HTTPS]"

FE --> BE : "Auth, patient & session CRUD\n[REST / Bearer JWT]"
FE --> AI : "/api/transcribe\n/api/generate-note\n/api/extract-entities\n[Internal HTTP]"
FE --> DB : "Direct CRUD via Supabase client\n[TLS / Row-Level Security]"
FE --> Notify : "mailto: / wa.me: / sms:\n[OS protocol handler]"

BE --> DB : "JPA/Hibernate\n[JDBC / TLS]"
BE --> Audit : "Append audit log on\nevery state change"

AI --> Sarvam : "POST audio buffer\n[HTTPS]"
AI --> Claude : "POST transcript prompt\n[HTTPS / Anthropic SDK]"

Audit --> DB : "INSERT audit_logs\n(append-only)"

@enduml
