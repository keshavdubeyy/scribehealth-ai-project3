# ─────────────────────────────────────────────────────────────────
# ScribeHealth AI — Environment Variables
# ─────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file:  cp .env.local.example .env.local
#   2. Fill in the values (ask the team lead for shared keys)
#   3. NEVER commit .env.local to git — it is already in .gitignore
# ─────────────────────────────────────────────────────────────────

# ── NextAuth ──────────────────────────────────────────────────────
# Used for signing JWT session tokens — must be the same on all machines
AUTH_SECRET=scribehealth_nextauth_super_secret_key_2026_xK9mP3qL8nR5wT2v

# ── Spring Boot Backend ───────────────────────────────────────────
# The Java backend runs locally on port 8081
NEXT_PUBLIC_API_BASE=http://localhost:8081/api

# ── Supabase (Shared DB — same for everyone) ──────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Sarvam AI (Speech-to-Text transcription) ─────────────────────
# Get from: https://dashboard.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key

# ── Anthropic Claude (SOAP note + entity extraction) ─────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key
